# ==========================================================
# Résidence Catalog — variables d'environnement
# Copier en .env et remplir avant `pnpm dev`
# ==========================================================

# --- Base de données ---
DATABASE_URL="postgresql://user:password@localhost:5432/residence_catalog"

# --- Redis (lock réservation + BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- Auth JWT ---
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too-different-from-jwt-secret"

# --- Serveur ---
PORT=3001

# --- CinetPay (paiements locaux XOF / mobile money) ---
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
CINETPAY_SECRET_KEY=""          # pour vérification signature webhook

# --- Stripe (paiements diaspora EUR) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""        # whsec_... pour vérification signature webhook

# --- Notifications push (à définir selon provider choisi) ---
# FIREBASE_PROJECT_ID=""
# FIREBASE_PRIVATE_KEY=""
# FIREBASE_CLIENT_EMAIL=""

# --- Email/SMS (à définir selon provider choisi) ---
# SMTP_HOST=""
# SMS_PROVIDER_API_KEY=""
